{
  "gateway": {
    "bindAddress": "127.0.0.1",
    "port": 18789,
    "authToken": "${OPENCLAW_AUTH_TOKEN}",
    "autoApproveLocalhost": false,
    "rateLimit": {
      "windowMs": 60000,
      "maxRequests": 30
    }
  },
  "exec": {
    "mode": "allowlist",
    "allowedCommands": [
      "node",
      "npx",
      "curl"
    ]
  },
  "skills": {
    "autoDiscovery": false,
    "trustedSources": [
      "./.agents/seer/skills/",
      "./.agents/edge/skills/",
      "./.agents/shield/skills/",
      "./.agents/lens/skills/"
    ]
  },
  "agents": [
    {
      "name": "seer",
      "soulPath": "./.agents/seer/soul.md",
      "skillsDir": "./.agents/seer/skills/",
      "model": {
        "provider": "0g-compute",
        "fallback": "anthropic"
      },
      "env": [
        "OG_RPC_URL",
        "OG_COMPUTE_BROKER_URL"
      ],
      "_security_note": "READ-ONLY: No wallet key. Seer reads chain data + runs 0G inference. Cannot sign transactions."
    },
    {
      "name": "edge",
      "soulPath": "./.agents/edge/soul.md",
      "skillsDir": "./.agents/edge/skills/",
      "model": {
        "provider": "0g-compute",
        "fallback": "anthropic"
      },
      "env": [
        "OG_RPC_URL",
        "HEDERA_OPERATOR_ID",
        "HEDERA_OPERATOR_KEY",
        "HEDERA_NETWORK",
        "HEDERA_USDC_TOKEN",
        "BLOCKY402_URL",
        "WALLET_PRIVATE_KEY"
      ],
      "_security_note": "PAYMENT AGENT: Only agent with wallet + Hedera keys. Signs x402 payments and prediction market trades."
    },
    {
      "name": "shield",
      "soulPath": "./.agents/shield/soul.md",
      "skillsDir": "./.agents/shield/skills/",
      "model": {
        "provider": "0g-compute",
        "fallback": "anthropic"
      },
      "env": [
        "OG_RPC_URL"
      ],
      "_security_note": "READ-ONLY: No wallet key. Shield reads ValidationRegistry + ReputationRegistry. Cannot sign any transaction."
    },
    {
      "name": "lens",
      "soulPath": "./.agents/lens/soul.md",
      "skillsDir": "./.agents/lens/skills/",
      "model": {
        "provider": "0g-compute",
        "fallback": "anthropic"
      },
      "env": [
        "OG_RPC_URL",
        "WALLET_PRIVATE_KEY"
      ],
      "_security_note": "WRITE-LIMITED: Has wallet key ONLY for writing reputation to ERC-8004 on 0G Chain. No Hedera keys, no payment authority."
    }
  ],
  "security": {
    "extensions": {
      "autoLoad": false,
      "directory": ""
    },
    "network": {
      "requireTLS": true
    }
  }
}
